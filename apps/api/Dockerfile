FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY src/Astra.Intranet.Api/Astra.Intranet.Api.csproj src/Astra.Intranet.Api/
RUN dotnet restore src/Astra.Intranet.Api/Astra.Intranet.Api.csproj
COPY src/Astra.Intranet.Api/ src/Astra.Intranet.Api/
RUN dotnet publish src/Astra.Intranet.Api/Astra.Intranet.Api.csproj -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS final
WORKDIR /app
RUN apt-get update \
    && apt-get install -y --no-install-recommends unixodbc \
    && rm -rf /var/lib/apt/lists/*
ENV ASPNETCORE_URLS=http://0.0.0.0:8080
COPY --from=build /app/publish .
EXPOSE 8080
ENTRYPOINT ["dotnet", "Astra.Intranet.Api.dll"]

