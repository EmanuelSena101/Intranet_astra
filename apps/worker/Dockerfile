FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY src/Astra.Intranet.Worker/Astra.Intranet.Worker.csproj src/Astra.Intranet.Worker/
RUN dotnet restore src/Astra.Intranet.Worker/Astra.Intranet.Worker.csproj
COPY src/Astra.Intranet.Worker/ src/Astra.Intranet.Worker/
RUN dotnet publish src/Astra.Intranet.Worker/Astra.Intranet.Worker.csproj -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/runtime:10.0 AS final
WORKDIR /app
RUN apt-get update \
    && apt-get install -y --no-install-recommends unixodbc \
    && rm -rf /var/lib/apt/lists/*
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "Astra.Intranet.Worker.dll"]

