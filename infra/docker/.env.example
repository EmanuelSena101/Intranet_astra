APP_NAME=astra-intranet-modern
HTTP_PORT=8080

WEB_IMAGE=ghcr.io/example/astra-intranet-web
API_IMAGE=ghcr.io/example/astra-intranet-api
WORKER_IMAGE=ghcr.io/example/astra-intranet-worker
IMAGE_TAG=latest

ASPNETCORE_ENVIRONMENT=Production

OPENEDGE_DSN=
OPENEDGE_CONNECTION_STRING=
OPENEDGE_HOST=
OPENEDGE_PORT=
OPENEDGE_DATABASE=
OPENEDGE_USERNAME=
OPENEDGE_PASSWORD=

BILHETAGEM_DIRECTORY_PROVIDER=auto
BILHETAGEM_DIRECTORY_TABLE_NAME=

BILHETAGEM_CALLS_PROVIDER=auto
BILHETAGEM_CALLS_TABLE_NAME=
BILHETAGEM_CALLS_DIRECTORY_TABLE_NAME=
BILHETAGEM_CALLS_USERS_TABLE_NAME=
BILHETAGEM_CALLS_DATE_FIELD=data
BILHETAGEM_CALLS_TIME_FIELD=hora
BILHETAGEM_CALLS_EXTENSION_FIELD=ramal
BILHETAGEM_CALLS_NUMBER_FIELD=numero
BILHETAGEM_CALLS_DURATION_FIELD=duracao
BILHETAGEM_CALLS_TYPE_CODE_FIELD=fl-ligacao
BILHETAGEM_CALLS_CITY_FIELD=cidade
BILHETAGEM_CALLS_STATE_FIELD=uf
BILHETAGEM_CALLS_COST_FIELD=custo
BILHETAGEM_CALLS_DESTINATION_FIELD=ramal-solicitado
BILHETAGEM_CALLS_OWNER_ID_FIELD=fc-codigo
BILHETAGEM_CALLS_DIRECTORY_NUMBER_FIELD=numero
BILHETAGEM_CALLS_DIRECTORY_DESCRIPTION_FIELD=descricao
BILHETAGEM_CALLS_USER_ID_FIELD=registro
BILHETAGEM_CALLS_USER_NAME_FIELD=nome

DOCWEB_PROVIDER=mock

ODBCINI=/etc/odbc.ini
ODBCSYSINI=/etc
OPENEDGE_DRIVER_HOME=/opt/openedge

PUBLIC_API_BASE_URL=/api
