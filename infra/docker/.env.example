APP_NAME=astra-intranet-modern
HTTP_PORT=8080

WEB_IMAGE=ghcr.io/example/astra-intranet-web
API_IMAGE=ghcr.io/example/astra-intranet-api
WORKER_IMAGE=ghcr.io/example/astra-intranet-worker
IMAGE_TAG=latest

ASPNETCORE_ENVIRONMENT=Production

# =============================================================================
# OpenEdge / ODBC
# -----------------------------------------------------------------------------
# Preencha essas variáveis para apontar a API ao OpenEdge corporativo.
# Deixando todas em branco, o container sobe em modo mock e
# /api/health/database retorna status=mock (200).
#
# O driver ODBC do Progress OpenEdge é licenciado e precisa ser baixado
# manualmente para infra/drivers/openedge/ antes do build. Ver
# docs/ODBC_SETUP.md para passo a passo.
# =============================================================================

# Nome da DSN gerada em /etc/odbc.ini pelo entrypoint do container api.
# Default: AstraOpenEdge. A API usa OpenEdge:Dsn para montar "DSN=...;UID=...;PWD=..."
OPENEDGE_DSN=AstraOpenEdge

# Host/porta onde o Progress OpenEdge está escutando (DataServer/SQL92).
OPENEDGE_HOST=
OPENEDGE_PORT=5555

# Nome lógico do banco no OpenEdge (DatabaseName).
OPENEDGE_DATABASE=

# Usuário e senha do OpenEdge (em produção use secrets, não um .env versionado).
# Aceita OPENEDGE_USER (preferido) ou OPENEDGE_USERNAME (legado).
OPENEDGE_USER=
OPENEDGE_PASSWORD=

# Opcional: se você já tem uma connection string ODBC pronta, descomente e
# ela será usada em vez das variáveis acima.
# OPENEDGE_CONNECTION_STRING=

# =============================================================================
# Módulo Bilhetagem (piloto)
# =============================================================================
BILHETAGEM_DIRECTORY_PROVIDER=auto
BILHETAGEM_DIRECTORY_TABLE_NAME=

BILHETAGEM_CALLS_PROVIDER=auto
BILHETAGEM_CALLS_TABLE_NAME=
BILHETAGEM_CALLS_DIRECTORY_TABLE_NAME=
BILHETAGEM_CALLS_USERS_TABLE_NAME=
BILHETAGEM_CALLS_DATE_FIELD=data
BILHETAGEM_CALLS_TIME_FIELD=hora
BILHETAGEM_CALLS_EXTENSION_FIELD=ramal
BILHETAGEM_CALLS_NUMBER_FIELD=numero
BILHETAGEM_CALLS_DURATION_FIELD=duracao
BILHETAGEM_CALLS_TYPE_CODE_FIELD=fl-ligacao
BILHETAGEM_CALLS_CITY_FIELD=cidade
BILHETAGEM_CALLS_STATE_FIELD=uf
BILHETAGEM_CALLS_COST_FIELD=custo
BILHETAGEM_CALLS_DESTINATION_FIELD=ramal-solicitado
BILHETAGEM_CALLS_OWNER_ID_FIELD=fc-codigo
BILHETAGEM_CALLS_DIRECTORY_NUMBER_FIELD=numero
BILHETAGEM_CALLS_DIRECTORY_DESCRIPTION_FIELD=descricao
BILHETAGEM_CALLS_USER_ID_FIELD=registro
BILHETAGEM_CALLS_USER_NAME_FIELD=nome

# =============================================================================
# DocWeb
# =============================================================================
DOCWEB_PROVIDER=mock

# =============================================================================
# Paths ODBC dentro do container (raramente precisam mudar)
# =============================================================================
ODBCINI=/etc/odbc.ini
ODBCSYSINI=/etc
OPENEDGE_DRIVER_HOME=/opt/progress/odbc

PUBLIC_API_BASE_URL=/api
